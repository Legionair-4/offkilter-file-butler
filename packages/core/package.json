{
  "name": "@offkilter/file-butler-core",
  "version": "0.1.0",
  "description": "Core runner for OffKilter File Butler.",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run test:standard && npm run test:custom",
    "test:standard": "npm run build && node --test dist/test/standard/*.test.js",
    "test:custom": "npm run build && node --test dist/test/custom/*.test.js"
  }
}
