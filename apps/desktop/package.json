{
  "name": "@offkilter/file-butler-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop shell for OffKilter File Butler.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "npm run build:bridge && npm run build:renderer",
    "build:bridge": "tsc -p tsconfig.bridge.json",
    "build:renderer": "tsc -p tsconfig.renderer.json --noEmit && vite build",
    "dev": "vite --host 127.0.0.1",
    "test": "npm run build:bridge && node --test test/*.test.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@offkilter/file-butler-core": "0.1.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2"
  }
}
