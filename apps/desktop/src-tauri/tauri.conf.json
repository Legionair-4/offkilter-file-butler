{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OffKilter File Butler",
  "version": "0.1.0",
  "identifier": "app.offkilter.file-butler",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "OffKilter File Butler",
        "width": 1180,
        "height": 780,
        "minWidth": 940,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
